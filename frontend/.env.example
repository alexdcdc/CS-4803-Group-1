# Copy this file to `.env` (gitignored) and edit as needed.
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the client bundle.

# API base URL. Leave unset to default to http://localhost:8000/api/v1.
# For production, point at the deployed backend:
# EXPO_PUBLIC_API_URL=https://api.quickstarter.xyz/api/v1
